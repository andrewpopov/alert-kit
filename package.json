{
  "name": "@andrewpopov/alert-kit",
  "version": "0.3.0",
  "description": "Transport-pluggable alert primitive with a built-in Discord transport: rich embeds, per-severity webhook routing, bounded timeout, 429 retry, graceful-degradation send, and a test seam.",
  "author": "Andrew Popov",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/andrewpopov/alert-kit.git" },
  "bugs": { "url": "https://github.com/andrewpopov/alert-kit/issues" },
  "homepage": "https://github.com/andrewpopov/alert-kit#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run verify:pack"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
